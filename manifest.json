      "name": "obsidian",
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "scope": "user",
      "env": {
        "OBSIDIAN_HOST": "127.0.0.1",
        "OBSIDIAN_PORT": "27124",
        "NODE_TLS_REJECT_UNAUTHORIZED": "0"
      },
      "note": "OBSIDIAN_API_KEY is injected by setup-mcp.sh to match the Local REST API plugin key."

{
  "schema": 1,
  "description": "Single source of truth for techtrip-secondbrain. bin/precheck.sh audits the machine against this; every bin/setup-*.sh consults it. macOS MVP.",
  "binaries": [
    { "cmd": "brew",   "label": "Homebrew",  "install": "see https://brew.sh" },
    { "cmd": "git",    "label": "git",       "install": "brew install git" },
    { "cmd": "node",   "label": "Node.js",   "install": "brew install node" },
    { "cmd": "uvx",    "label": "uv / uvx",  "install": "brew install uv" },
    { "cmd": "yt-dlp", "label": "yt-dlp",    "install": "brew install yt-dlp" }
  ],
  "apps": [
    { "name": "Obsidian", "cask": "obsidian", "check": "/Applications/Obsidian.app" }
  ],
  "claudePlugins": [
    {
      "id": "claude-obsidian",
      "author": "AgriciDaniel",
      "authorUrl": "https://github.com/AgriciDaniel",
      "homepage": "https://github.com/AgriciDaniel/claude-obsidian",
      "marketplace": "AgriciDaniel/claude-obsidian",
      "slug": "claude-obsidian@agricidaniel-claude-obsidian",
      "license": "MIT",
      "testedVersion": "1.9.2",
      "note": "By AgriciDaniel (https://github.com/AgriciDaniel/claude-obsidian), MIT. Pulled from his marketplace at install time — NOT vendored or forked. The CLI can't pin versions, so testedVersion is advisory: setup-claude-obsidian.sh warns if the installed version differs from the one this project was tested against."
    }
  ],
  "obsidianPluginsNote": "Each plugin is PINNED to a release tag, and every downloaded asset is verified against its sha256 before install (supply-chain guard: a hijacked upstream release fails loudly instead of installing silently). Refresh pins + hashes with: bash scripts/pin-obsidian-plugins.sh",

{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": ".github/hooks/wiki-session-start.sh"
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": ".github/hooks/wiki-autocommit.sh"
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": ".github/hooks/wiki-stop-reminder.sh"
      }
    ]
  }
}

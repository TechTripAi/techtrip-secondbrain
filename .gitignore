# techtrip-secondbrain is an installer/orchestrator repo (no vault lives here).

# System
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# Local secrets / env
.env
.env.local

# Private keys and credentials (defense-in-depth — never commit these)
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*
credentials*
secrets.y*ml
auth.json

# Cross-script state (written to ~/.config normally; ignore if it ever lands here)
.tsb-state
